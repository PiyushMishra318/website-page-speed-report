{
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/pagespeed.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/pagespeed", "destination": "/api/pagespeed" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
